---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Message Sent | Bosker Excavating & Trucking" description="Thank you for contacting Bosker Excavating and Trucking. We'll be in touch soon.">

  <section class="thanks-section">
    <div class="container">
      <div class="thanks-card">
        <div class="thanks-icon">&#10003;</div>
        <h1>Thanks for reaching out!</h1>
        <p class="lead">Your message has been sent. We'll get back to you within 24 hours.</p>
        <p>Need a faster response? Give us a call directly:</p>
        <a href="tel:+12314993784" class="phone-cta">(231) 499-3784</a>

        <div class="thanks-actions">
          <a href={base} class="btn btn-secondary">Back to Home</a>
          <a href={`${base}services/`} class="btn btn-primary">View Our Services</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .thanks-section {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem;
    background: var(--color-gray-100);
  }

  .thanks-card {
    background: var(--color-white);
    border-radius: 12px;
    padding: 4rem 3rem;
    max-width: 600px;
    text-align: center;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
    border-top: 4px solid var(--color-accent);
  }

  .thanks-icon {
    width: 80px;
    height: 80px;
    background: var(--color-accent);
    color: var(--color-dark);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    font-weight: 800;
    margin: 0 auto 1.5rem;
  }

  .thanks-card h1 {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    color: var(--color-dark);
    margin-bottom: 1rem;
  }

  .lead {
    font-size: 1.15rem;
    color: var(--color-gray-700);
    margin-bottom: 2rem;
  }

  .thanks-card > p:not(.lead) {
    color: var(--color-gray-700);
    margin-bottom: 0.5rem;
  }

  .phone-cta {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 1.75rem;
    color: var(--color-dark);
    font-weight: 700;
    margin-bottom: 2.5rem;
    padding: 0.5rem 1.5rem;
    background: var(--color-accent);
    border-radius: 6px;
    transition: transform 0.2s;
  }

  .phone-cta:hover {
    transform: translateY(-2px);
  }

  .thanks-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  @media (max-width: 600px) {
    .thanks-card {
      padding: 2.5rem 1.5rem;
    }
    .thanks-card h1 {
      font-size: 1.75rem;
    }
  }
</style>
